                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Returns a Spring Page object with content, totalPages, totalElements, etc.\n\nExpected: 200 OK  {content: [...], totalPages: N, ...}"
          }
        },
        {
